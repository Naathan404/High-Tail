  m_Script: {fileID: 11500000, guid: 4298c1582b1a1b6428acd6f21334c2fe, type: 3}
  m_Name: YatElder
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  Name:
    textVI: "Yat Gi\xE0"
    textEN: Yat Elder
  CharSprite: {fileID: 7160429211405778527, guid: 607e7b2b21dd4e34c9dab483a858cb93, type: 3}
  DialogueLines:
  - IsYou: 0
    textVI: "Ch\xE0o nh\xF3c"
    textEN: Hi kid
    autoSkip: 0
  - IsYou: 0
    textVI: "L\xE2u l\u1EAFm r\u1ED3i ta m\u1EDBi l\u1EA1i th\u1EA5y c\xF3 sinh v\u1EADt
      d\xE1m \u0111\u1EBFn n\u01A1i n\xE0y."
    textEN: I havn't seen anyone come to this place for a long time.
    autoSkip: 0
  - IsYou: 0
    textVI: "Ta s\u1ED1ng \u1EDF \u0111\xE2y c\u0169ng \u0111\u01B0\u1EE3c 36 n\u0103m
      r\u1ED3i. Nh\xF3c c\xF3 th\u1EC3 g\u1ECDi ta l\xE0 Gi\xE0 L\xE0ng."
    textEN: I've been lived here for 36 years. You can call me Yat Elder.
    autoSkip: 0
  - IsYou: 1
    textVI: "Oh xin ch\xE0o th\u1EB1ng kh\u1ECDm gi\xE0"
    textEN: 'Yo what''s up you dumb old yat. '
    autoSkip: 0
  - IsYou: 0
    textVI: "Xem nh\u01B0 l\xE0 qu\xE0 g\u1EB7p m\u1EB7t, ta s\u1EBD d\u1EA1y ch\xE1u
      c\xE1ch chinh ph\u1EE5c nh\u1EEFng b\u1EE9c t\u01B0\u1EDDng, th\u1EE9 m\xE0
      nh\u1EEFng chi\u1EBFn binh nh\u01B0 b\u1ECDn ta t\u1EEBng r\u1EA5t gi\u1ECFi"
    textEN: I will teach you how to be the king of wall.
    autoSkip: 0
  - IsYou: 1
    textVI: Ok xie xie
    textEN: Xie xie you and pai pai
    autoSkip: 0
  EndDialogue: 
  AutoProgressDelay: 1.5
  TypingSpeed: 0.02
  VoiceSound: {fileID: 0}
  VoicePitch: 1
