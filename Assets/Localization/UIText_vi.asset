    m_Metadata:
      m_Items: []
  - m_Id: 1853463937024
    m_Localized: "Trang ch\u1EE7"
    m_Metadata:
      m_Items: []
  - m_Id: 20684907429888
    m_Localized: "Ch\u1ECDn ho\u1EB7c t\u1EA1o m\u1ED9t game \u0111\u1EC3 ch\u01A1i!"
    m_Metadata:
      m_Items: []
  - m_Id: 23357442441216
    m_Localized: "Ng\xF4n ng\u1EEF:"
    m_Metadata:
      m_Items: []
  - m_Id: 23595938955264
    m_Localized: "Ti\u1EBFng Anh"
    m_Metadata:
      m_Items: []
  - m_Id: 23705158631424
    m_Localized: "Ti\u1EBFng Vi\u1EC7t"
    m_Metadata:
      m_Items: []
  - m_Id: 32772337909760
    m_Localized: "X\xE1c nh\u1EADn x\xF3a game?"
    m_Metadata:
      m_Items: []
  - m_Id: 33937431674880
    m_Localized: "Kh\xF4ng th\u1EC3 x\xF3a file \u0111ang ch\u01A1i!"
    m_Metadata:
      m_Items: []
  - m_Id: 34015634472960
    m_Localized: "B\u1EA1n c\xF3 ch\u1EAFc ch\u1EAFn mu\u1ED1n x\xF3a\\n'{0}' kh\xF4ng?"
    m_Metadata:
      m_Items: []
  - m_Id: 35207794081792
    m_Localized: "\u0110\xE3 chuy\u1EC3n \u0111\u1EBFn '{0}'!"
    m_Metadata:
      m_Items: []
  - m_Id: 35960965251072
    m_Localized: "T\u1EA3i game th\u1EA5t b\u1EA1i"
    m_Metadata:
      m_Items: []
  - m_Id: 36558041202688
