  nameText:
    nameVI: "Tr\u01B0\u1EDFng l\xE0ng"
    nameEN: Village Chief
  dialogueLines:
  - image: {fileID: 10907, guid: 0000000000000000f000000000000000, type: 0}
    textVI: "\xC0 Fu \u0111\xE2y r\u1ED3i"
    textEN: Fu, there you are
    autoSkip: 0
  - image: {fileID: 0}
    textVI: "T\xECnh c\u1EA3nh b\xE2y gi\u1EDD r\u1EA5t l\xE0 nguy hi\u1EC3m"
    textEN: We're all on the edge
    autoSkip: 0
  - image: {fileID: 0}
    textVI: "H\xE3y ti\xEAu di\u1EC7t h\u1EAFn \u0111\u1EC3 c\u1EE9u ch\xFAng ta"
    textEN: Defeat him to save us
    autoSkip: 0
  endDialogue: 
